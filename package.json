{
  "name": "slot-machine",
  "version": "1.0.0",
  "description": "Browser-based slot machine app",
  "main": "src/server/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server/server.js",
    "dev": "nodemon src/server/server.js",
    "dev:debug": "DEV_MODE=true nodemon src/server/server.js",
    "build:css": "sass src/client/scss/main.scss src/client/css/styles.css --style=compressed",
    "watch:css": "sass --watch src/client/scss/main.scss:src/client/css/styles.css",
    "lint:js": "eslint \"src/client/js/**/*.js\" \"src/server/**/*.js\"",
    "lint:scss": "stylelint \"src/client/scss/**/*.scss\"",
    "lint:html": "htmlhint src/client/index.html",
    "lint": "npm run lint:js && npm run lint:scss && npm run lint:html",
    "test:unit": "node --test src/tests/unit/**/*.test.js",
    "test:e2e": "playwright test src/tests/e2e/",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "keywords": [],
  "author": "Brendan Barber",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.1",
    "htmlhint": "^1.9.2",
    "nodemon": "^3.1.14",
    "sass": "^1.99.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0"
  }
}
